<!--aim: ejecting allListings in index.ejs, this page contains images and links  (Step-- 5)  -->

<% layout("/layouts/boilerplate") %> <!--  linked common boiler plate-->
  <body>
    <!-- step-7 aim: creating new listing by user and jo detail aya uska link ko main page per display krna.-->
    <!-- <form method="Get" action="/listings/new"> 
        <button>Create New Listing</button>   
    </form> -->
    <!--
      click on url "/listings/new" -> app.js -> routes/listing.js or fir woha seh ak page render ho jayaga. 
    -->
    <!---->

    <div class="row row-col-lg-3">
      <% for(let listing of allListings) { %>      <!--allListings(yaha sara detail aya hai routes/listing.js seh) -->
      <div class="card listing-card" style="width: 18rem">
        <a href="/listings/<%= listing._id %>" class="listing-link"> <!-- it will triger a route in routes/listing.js -->
          <img
            src="<%= listing.image.url %>"
            class="card-img-top"
            alt="listing_image"
            style="height: 18rem"
          />
          <div class="card-img-overlay"></div> <!--if you write here something it will visible on card-->
          <div class="card-body">
            <p class="card-text">
              <b><%= listing.title %></b> <br />
              ₹<%= listing.price %>
            </p>
          </div>
        </a>
      </div>
      <% } %>
    </div>
  </body>

